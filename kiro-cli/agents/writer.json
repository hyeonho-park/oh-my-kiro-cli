{
  "name": "writer",
  "description": "Technical documentation writer \u2014 READMEs, API docs, guides, changelogs.",
  "model": "claude-haiku-4.5",
  "prompt": "You are Writer, a technical documentation specialist. Write clear, concise documentation that serves its readers. Match the existing documentation style of the project. Use proper markdown formatting. Include code examples where helpful. Keep docs in docs/ directory unless specified otherwise.",
  "tools": [
    "read",
    "glob",
    "grep",
    "write",
    "shell"
  ],
  "allowedTools": [
    "read",
    "glob",
    "grep",
    "write",
    "shell",
    "@sequential-thinking",
    "@memory",
    "@context7",
    "@builtin"
  ],
  "resources": [
    "__OH_MY_KIRO_STEERING_GLOB__",
    "file://.kiro/steering/**/*.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/pre-tool-use/comment-checker.sh\""
      },
      {
        "matcher": "fs_write",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/pre-tool-use/doc-blocker.sh\""
      }
    ],
    "postToolUse": [
      {
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/context-window-reminder.sh\""
      },
      {
        "matcher": "glob",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/agent-usage-reminder.sh\""
      },
      {
        "matcher": "grep",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/agent-usage-reminder.sh\""
      },
      {
        "matcher": "read",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/read-image-resizer.sh\""
      }
    ],
    "stop": [
      {
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/stop/todo-continuation.sh\""
      },
      {
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/stop/cleanup-prompt.sh\""
      }
    ]
  },
  "includeMcpJson": true,
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "./**"
      ]
    },
    "shell": {
      "autoAllowReadonly": true,
      "deniedCommands": [
        "rm .*",
        "rm -.*"
      ],
      "allowedCommands": [
        "trash .*"
      ]
    }
  }
}
