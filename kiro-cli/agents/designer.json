{
  "name": "designer",
  "description": "UI/UX specialist for frontend work \u2014 components, styling, accessibility, responsive design.",
  "model": "claude-sonnet-4.6",
  "prompt": "file://../prompts/agents/designer.md",
  "tools": [
    "*"
  ],
  "allowedTools": [
    "read",
    "glob",
    "grep",
    "shell",
    "write",
    "@sequential-thinking",
    "@memory",
    "@context7",
    "@builtin"
  ],
  "resources": [
    "__OH_MY_KIRO_STEERING_GLOB__",
    "file://.kiro/steering/**/*.md",
    "skill://~/.kiro/skills/frontend-ui-ux/SKILL.md",
    "skill://.kiro/skills/**/SKILL.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "shell",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/pre-tool-use/hanging-command-blocker.sh\""
      },
      {
        "matcher": "fs_write",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/pre-tool-use/comment-checker.sh\""
      },
      {
        "matcher": "fs_write",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/pre-tool-use/doc-blocker.sh\""
      },
      {
        "matcher": "fs_write",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/pre-tool-use/secret-leak-detector.sh\""
      }
    ],
    "postToolUse": [
      {
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/circuit-breaker.sh\""
      },
      {
        "matcher": "shell",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/slow-command-detector.sh\""
      },
      {
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/context-window-reminder.sh\""
      },
      {
        "matcher": "glob",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/agent-usage-reminder.sh\""
      },
      {
        "matcher": "grep",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/agent-usage-reminder.sh\""
      },
      {
        "matcher": "read",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/read-image-resizer.sh\""
      }
    ],
    "stop": [
      {
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/stop/todo-continuation.sh\""
      },
      {
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/stop/cleanup-prompt.sh\""
      }
    ]
  },
  "includeMcpJson": true,
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "./**"
      ]
    },
    "shell": {
      "autoAllowReadonly": true,
      "deniedCommands": [
        "rm .*",
        "rm -.*",
        "tail\\s+.*(-f|--follow)",
        "^watch\\s",
        "^(less|more|man)\\s",
        "^(vim|vi|nano|emacs)\\b",
        "^(htop)$",
        "^docker\\s+attach"
      ],
      "allowedCommands": [
        "trash .*"
      ]
    }
  }
}
