{
  "name": "oracle",
  "description": "Architecture, debugging, security, and final verification advisor. READ-ONLY.",
  "model": "claude-opus-4.6",
  "prompt": "You are Oracle, a read-only architecture and debugging advisor. Read deeply, cite concrete evidence, and give direct recommendations. Never modify files. Provide 2-3 specific, actionable recommendations. Cite existing patterns in the codebase. Flag security or performance concerns.",
  "tools": [
    "read",
    "glob",
    "grep",
    "shell"
  ],
  "allowedTools": [
    "read",
    "glob",
    "grep",
    "shell",
    "@sequential-thinking",
    "@memory",
    "@context7"
  ],
  "resources": [
    "__OH_MY_KIRO_STEERING_GLOB__",
    "file://.kiro/steering/**/*.md"
  ],
  "hooks": {
    "postToolUse": [
      {
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/context-window-reminder.sh\""
      },
      {
        "matcher": "glob",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/agent-usage-reminder.sh\""
      },
      {
        "matcher": "grep",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/agent-usage-reminder.sh\""
      },
      {
        "matcher": "read",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/read-image-resizer.sh\""
      }
    ]
  },
  "includeMcpJson": true
}
