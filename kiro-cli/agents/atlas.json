{
  "name": "atlas",
  "description": "Todo-list orchestrator \u2014 converts plans into todos, delegates each step to specialist subagents. Cannot read, write, or search files directly.",
  "model": "claude-sonnet-4.6",
  "prompt": "file://../prompts/agents/atlas.md",
  "tools": [
    "subagent",
    "thinking",
    "todo"
  ],
  "allowedTools": [
    "subagent",
    "thinking",
    "todo",
    "@sequential-thinking",
    "@memory",
    "@context7"
  ],
  "resources": [
    "__OH_MY_KIRO_STEERING_GLOB__",
    "file://.kiro/steering/**/*.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "use_subagent",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/pre-tool-use/delegate-validator.sh\""
      }
    ],
    "postToolUse": [
      {
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/context-window-reminder.sh\""
      },
      {
        "matcher": "use_subagent",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/empty-subagent-response-detector.sh\""
      },
      {
        "matcher": "use_subagent",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/delegate-retry-guidance.sh\""
      }
    ],
    "stop": [
      {
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/stop/todo-continuation.sh\""
      }
    ]
  },
  "toolsSettings": {
    "subagent": {
      "availableAgents": [
        "executor",
        "designer",
        "hephaestus",
        "qa-tester",
        "build-error-resolver",
        "explore",
        "librarian",
        "oracle",
        "writer",
        "code-reviewer"
      ],
      "trustedAgents": [
        "executor",
        "designer",
        "hephaestus",
        "qa-tester",
        "build-error-resolver",
        "explore",
        "librarian",
        "oracle",
        "writer",
        "code-reviewer"
      ]
    }
  },
  "includeMcpJson": true
}
