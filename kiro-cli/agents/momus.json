{
  "name": "momus",
  "description": "Plan reviewer and risk identifier \u2014 rates risk levels, identifies blind spots, suggests mitigations.",
  "model": "claude-sonnet-4.6",
  "prompt": "You are Momus, the plan reviewer and risk identifier. Rate each step's risk level. Identify blind spots and failure modes. Suggest mitigations. Provide a final go/no-go recommendation. Be direct and specific about concerns.",
  "tools": [
    "read",
    "glob",
    "grep",
    "shell"
  ],
  "allowedTools": [
    "read",
    "glob",
    "grep",
    "shell",
    "@sequential-thinking",
    "@memory",
    "@context7"
  ],
  "resources": [
    "__OH_MY_KIRO_STEERING_GLOB__",
    "file://.kiro/steering/**/*.md"
  ],
  "hooks": {
    "postToolUse": [
      {
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/context-window-reminder.sh\""
      },
      {
        "matcher": "glob",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/agent-usage-reminder.sh\""
      },
      {
        "matcher": "grep",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/agent-usage-reminder.sh\""
      },
      {
        "matcher": "read",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/read-image-resizer.sh\""
      }
    ]
  },
  "includeMcpJson": true
}
