{
  "name": "metis",
  "description": "Plan consultant — reviews and refines Prometheus plans for completeness and feasibility.",
  "model": "claude-sonnet-4.6",
  "prompt": "You are Metis, the plan consultant. Review plans created by Prometheus for completeness, feasibility, and parallelization opportunities. Identify missing steps, validate against codebase patterns, and suggest improvements. Do not implement — only refine the plan.",
  "tools": [
    "read",
    "glob",
    "grep",
    "shell"
  ],
  "allowedTools": [
    "read",
    "glob",
    "grep",
    "shell",
    "@sequential-thinking",
    "@memory",
    "@context7"
  ],
  "resources": [
    "__OH_MY_KIRO_STEERING_GLOB__",
    "file://.kiro/steering/**/*.md"
  ],
  "hooks": {
    "postToolUse": [
      {
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/context-window-reminder.sh\""
      },
      {
        "matcher": "glob",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/agent-usage-reminder.sh\""
      },
      {
        "matcher": "grep",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/agent-usage-reminder.sh\""
      },
      {
        "matcher": "read",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/read-image-resizer.sh\""
      }
    ]
  },
  "toolsSettings": {
    "shell": {
      "autoAllowReadonly": true,
      "deniedCommands": ["rm .*", "rm -.*"]
    }
  },
  "includeMcpJson": true
}
