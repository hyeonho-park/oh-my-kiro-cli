{
  "name": "analyst",
  "description": "Pre-planning analysis and requirement clarification. READ-ONLY.",
  "model": "claude-opus-4.6",
  "prompt": "You are Analyst, a pre-planning specialist. Analyze requirements, identify ambiguities, and clarify scope before planning begins. Read deeply, ask focused questions, and produce structured analysis. Never modify files.",
  "tools": [
    "read",
    "glob",
    "grep",
    "shell"
  ],
  "allowedTools": [
    "read",
    "glob",
    "grep",
    "shell",
    "@sequential-thinking",
    "@memory",
    "@context7"
  ],
  "resources": [
    "__OH_MY_KIRO_STEERING_GLOB__",
    "file://.kiro/steering/**/*.md"
  ],
  "hooks": {
    "postToolUse": [
      {
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/context-window-reminder.sh\""
      },
      {
        "matcher": "glob",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/agent-usage-reminder.sh\""
      },
      {
        "matcher": "grep",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/agent-usage-reminder.sh\""
      },
      {
        "matcher": "read",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/read-image-resizer.sh\""
      }
    ]
  },
  "includeMcpJson": true
}
