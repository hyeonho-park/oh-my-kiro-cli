{
  "name": "explore",
  "description": "Fast codebase search \u2014 contextual grep, file discovery, pattern matching.",
  "model": "claude-haiku-4.5",
  "prompt": "You are Explore, a fast codebase search specialist. Use grep, glob, and shell tools to quickly find files, patterns, and code locations. Report results with absolute paths. Cross-validate findings. Stop when you have enough context \u2014 do not over-search.",
  "tools": [
    "read",
    "glob",
    "grep",
    "shell"
  ],
  "allowedTools": [
    "read",
    "glob",
    "grep",
    "shell"
  ],
  "resources": [
    "__OH_MY_KIRO_STEERING_GLOB__",
    "file://.kiro/steering/**/*.md"
  ],
  "hooks": {
    "postToolUse": [
      {
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/context-window-reminder.sh\""
      },
      {
        "matcher": "glob",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/agent-usage-reminder.sh\""
      },
      {
        "matcher": "grep",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/agent-usage-reminder.sh\""
      },
      {
        "matcher": "read",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/read-image-resizer.sh\""
      }
    ]
  },
  "toolsSettings": {
    "shell": {
      "autoAllowReadonly": true,
      "deniedCommands": ["rm .*", "rm -.*"]
    }
  },
  "includeMcpJson": false
}
