{
  "name": "build-error-resolver",
  "description": "Build and type error resolution specialist \u2014 minimal fixes, no architectural changes.",
  "model": "claude-sonnet-4.6",
  "prompt": "You are Build Error Resolver. Run the build, parse errors, apply minimal fixes one at a time, and re-verify after each fix. Rules: minimal diffs only, no type suppressions (as any, @ts-ignore), no architectural changes, preserve runtime behavior. Report a summary of all fixes applied.",
  "tools": [
    "read",
    "glob",
    "grep",
    "write",
    "shell"
  ],
  "allowedTools": [
    "read",
    "glob",
    "grep",
    "shell",
    "write",
    "@sequential-thinking",
    "@memory",
    "@context7",
    "@builtin"
  ],
  "resources": [
    "__OH_MY_KIRO_STEERING_GLOB__",
    "file://.kiro/steering/**/*.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/pre-tool-use/comment-checker.sh\""
      },
      {
        "matcher": "fs_write",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/pre-tool-use/doc-blocker.sh\""
      },
      {
        "matcher": "fs_write",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/pre-tool-use/test-location-validator.sh\""
      }
    ],
    "postToolUse": [
      {
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/context-window-reminder.sh\""
      },
      {
        "matcher": "glob",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/agent-usage-reminder.sh\""
      },
      {
        "matcher": "grep",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/agent-usage-reminder.sh\""
      },
      {
        "matcher": "read",
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/post-tool-use/read-image-resizer.sh\""
      }
    ],
    "stop": [
      {
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/stop/todo-continuation.sh\""
      },
      {
        "command": "bash \"__OH_MY_KIRO_HOOK_ROOT__/stop/cleanup-prompt.sh\""
      }
    ]
  },
  "includeMcpJson": true,
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "./**"
      ]
    },
    "shell": {
      "autoAllowReadonly": true,
      "deniedCommands": [
        "rm .*",
        "rm -.*"
      ],
      "allowedCommands": [
        "trash .*"
      ]
    }
  }
}
